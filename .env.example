# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-in-production-use-32-random-chars
JWT_SECRET_KEY=jwt-secret-change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///road_damage.db
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost:5432/road_damage

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Admin seed ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@roaddamage.ai
ADMIN_PASSWORD=Admin@1234

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
WEIGHTS_DIR=weights

# ── Email alerts ──────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@roaddamage.ai
ALERT_RECIPIENTS=inspector@city.gov,manager@roads.gov

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── OpenWeatherMap ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=

# ── OpenAI (chatbot) ──────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Alert thresholds ──────────────────────────────────────────────────────────
ALERT_CONFIDENCE_THRESHOLD=0.85

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:5000
